rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leads: only Cloud Functions (admin SDK) can write.
    // No client-side read/write allowed.
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
